# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ANTHROPIC_API_KEY: Optional if you use direct Claude integration, otherwise falls back to Gemini API
# CLOSE_API_KEY: Optional if syncing scraped leads with Close.io CRM
ANTHROPIC_API_KEY=
CLOSE_API_KEY=

# Vercel Sandbox + agent-browser config
VERCEL_AI_GATEWAY_KEY=

# BROWSER_USE_API_KEY: API key for Browser Use Cloud API to run remote agent tasks
BROWSER_USE_API_KEY=

# Stealth Browser MCP Engine config
STEALTH_BROWSER_URL=
STEALTH_BROWSER_TOKEN=

# LINKEDIN_AGENT_URL: Base URL of the LinkedIn outreach REST API running separately
LINKEDIN_AGENT_URL=

# Exa API Key for target company searches
EXA_API_KEY=

# Browserbase Credentials for Playwright sessions
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Optional custom base URL for OpenAI-compatible Gemini endpoints
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Crawl4AI Content Extraction Engine
CRAWL4AI_URL=https://crawl4ai-production-8e63.up.railway.app

# Standing Browser Automation Microservice URL (Deployed on Railway)
BROWSER_SERVICE_URL=


